# ===== DeepSeek AI 指令配置 =====
# 在 https://platform.deepseek.com/api_keys 创建 API Key
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===== Supabase 云端同步配置（可选）=====
# 1. 访问 https://supabase.com 创建项目
# 2. 在 Settings → API 中获取 URL 和 anon key
# 3. 在 Supabase SQL Editor 中执行 supabase-setup.sql

# 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# anon public 密钥
VITE_SUPABASE_ANON_KEY=your-anon-key

# 同步表名（默认，不需要修改）
VITE_SUPABASE_SYNC_TABLE=devtrack_sync_records
VITE_SUPABASE_PROJECT_TABLE=devtrack_projects
VITE_SUPABASE_MEMBER_TABLE=devtrack_project_members