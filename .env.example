# ===== DeepSeek AI command config =====
# VITE_ variables are bundled into frontend code. For one-time use, prefer
# entering the DeepSeek key in the app instead of saving it here.
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===== Supabase cloud sync config, optional =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Table names, normally unchanged.
VITE_SUPABASE_SYNC_TABLE=devtrack_sync_records
VITE_SUPABASE_PROJECT_TABLE=devtrack_projects
VITE_SUPABASE_MEMBER_TABLE=devtrack_project_members

# Public Edge Function URL for beta account deletion.
# Do not put a service-role key in any VITE_ variable.
VITE_SUPABASE_DELETE_ACCOUNT_FUNCTION_URL=https://your-project.supabase.co/functions/v1/devtrack-delete-account
